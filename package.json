{
  "name": "music888",
  "version": "1.0.0",
  "description": "沄听 - 在线音乐播放器，支持多平台搜索、高品质播放、歌词显示",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:proxy": "node --input-type=module -e \"import { startVitest } from 'vitest/node'; const ctx = await startVitest('test', ['functions/api/proxy.test.ts'], { config: false, root: process.cwd(), globals: true, environment: 'jsdom', include: ['functions/api/**/*.test.ts'], exclude: ['tests/e2e/**'], watch: false }); const failedFiles = ctx.state.getFiles().filter(file => file.result?.state === 'fail').length; await ctx.close(); process.exit(failedFiles > 0 ? 1 : 0);\"",
    "test:run": "npm run test:proxy && vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.ts tests/e2e/mobile-smoke.spec.ts",
    "lint": "eslint js tests *.ts --ext .ts",
    "lint:e2e": "eslint playwright.config.ts vitest.config.ts tests/e2e/*.ts --ext .ts",
    "lint:fix": "eslint js tests *.ts --ext .ts --fix",
    "format": "prettier --write \"js/**/*.ts\" \"tests/**/*.ts\" \"*.ts\" \"css/**/*.css\""
  },
  "keywords": [
    "music",
    "player",
    "typescript",
    "vite"
  ],
  "author": "truelife0958",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.1.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1",
    "vite": "^7.1.10",
    "vitest": "^4.0.18"
  }
}
